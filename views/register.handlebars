<h1>{{#if isEditing}}Edit Profile{{else}}Register{{/if}}</h1>

{{#if error}}
  <p class='error'>{{error}}</p>
{{/if}}

<form action='{{#if action}}{{action}}{{else}}/register{{/if}}' method='POST'>
  <label for='firstName'>First Name:</label>
  <input type='text' name='firstName' id='firstName' value='{{firstName}}' required >

  <br >

  <label for='lastName'>Last Name:</label>
  <input type='text' name='lastName' id='lastName' value='{{lastName}}' required >

  <br >

  <label for='email'>Email:</label>
  <input type='email' name='email' id='email' value='{{email}}' required >

  <br >

  <label for='password'>Password:</label>
  <input type='password' name='password' id='password' {{#unless isEditing}}required{{/unless}} >

  {{#if isEditing}}
    <p class='message'>Leave this blank if you don't want to change it.</p>

    <fieldset>
      <legend>Notifications</legend>
      <label>
        <input type='checkbox' name='notificationPrefs' value='email' {{#if prefEmail}}checked{{/if}} >
        Email
      </label>
      <label>
        <input type='checkbox' name='notificationPrefs' value='inApp' {{#if prefInApp}}checked{{/if}} >
        In-app
      </label>
    </fieldset>
  {{/if}}

  <br >

  <button type='submit'>{{#if isEditing}}Save Changes{{else}}Register{{/if}}</button>
</form>

{{#if isEditing}}
  <p>
    <a href='/profile'>Return to profile</a>
  </p>
{{else}}
  <p>
    Already have an account?
    <a href='/signin'>Sign in here</a>
  </p>
  <p>
    <a href='/'>Home</a>
  </p>
{{/if}}