<h1>Edit a Building</h1>

{{#if error}}
  <p class="error">{{error}}</p>
{{/if}}

{{#if success}}
  <p class="success">{{success}}</p>
{{/if}}

<h2>Look Up Building</h2>

<form action="/admin/edit" method="POST" id="adminEditLookupForm">
  <div>
    <label for="lookupBIN">BIN Number:</label>
    <input
      type="number"
      id="lookupBIN"
      name="BIN"
      value="{{formData.BIN}}"
      min="1"
      step="1"
      required
    >
  </div>

  <div>
    <button type="submit">Find Building</button>
  </div>
</form>

{{#if building}}
  <h2>Edit Building Data</h2>

  <form action="/admin/edit/submit" method="POST" id="adminEditSubmitForm">
    <input
      type="hidden"
      name="originalBIN"
      value="{{#if building.originalBIN}}{{building.originalBIN}}{{else}}{{building.BIN}}{{/if}}"
    >

    <p>
      <span class="label">Current BIN:</span>
      {{#if building.originalBIN}}{{building.originalBIN}}{{else}}{{building.BIN}}{{/if}}
    </p>

    <div>
      <label for="Address">Address:</label>
      <input
        type="text"
        id="Address"
        name="Address"
        value="{{building.address}}"
        maxlength="200"
        required
      >
    </div>

    <div>
      <label for="BIN">BIN Number:</label>
      <input
        type="number"
        id="BIN"
        name="BIN"
        value="{{building.BIN}}"
        min="1"
        step="1"
        required
      >
    </div>


    <div>
      <button type="submit">Update Building</button>
    </div>
  </form>
{{/if}}

<p><a href="/admin">Back to Admin Dashboard</a></p>