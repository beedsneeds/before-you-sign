<h1>Delete Building</h1>

{{#if error}}
  <p>{{error}}</p>
{{/if}}

{{#if success}}
  <p>{{success}}</p>
{{/if}}

<h2>Look Up Building</h2>

<form action="/admin/delete" method="POST">
  <div>
    <label for="BuildingID">Building ID:</label>
    <input
      type="number"
      id="BuildingID"
      name="BuildingID"
      value="{{formData.BuildingID}}"
      required
    >
  </div>

  <div>
    <button type="submit">Find Building</button>
  </div>
</form>

{{#if building}}
  <h2>Confirm Delete</h2>

  <p><strong>Building ID:</strong> {{building.BIN}}</p>
  <p><strong>Address:</strong> {{building.address}}</p>
  <p><strong>BIN Number:</strong> {{building.BIN}}</p>
  <p><strong>Average Rating:</strong> {{building.avgRating}}</p>
  <p><strong>Reviews Count:</strong> {{building.reviewsCount}}</p>

 <form action="/admin/delete/confirm" method="POST">
  <input
    type="hidden"
    name="BuildingID"
    value="{{building.BIN}}"
  />

  <button type="submit">Confirm Delete</button>
</form>
{{/if}}

<p><a href="/admin">Back to Admin Dashboard</a></p>