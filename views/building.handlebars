<h1>{{building.address}}</h1>
<p>ID: {{building.BIN}}</p>

<p>Avg Rating: {{building.avgRating}}</p>
<p>Reviews Count: {{building.reviewsCount}}</p>

<h2>Reviews</h2>
{{#each reviews}}
  {{> reviewscard}}
{{/each}}


<h3>Add a review</h3>
<form method='POST' action='/building/{{building.BIN}}/review'>
  <label for='reviewText'>Review:</label>
  <input type='text' id='reviewText' name='reviewText' placeholder='Please write a review' />

  <label for='rating'>Rating (1-5):</label>
  <input
  type='number'
  id='rating'
  name='rating'
  min='1'
  max='5'
  required
/>

  <button type='submit'>Submit</button>
</form>
{{#if review_confirm_submit}}
  <p>Review submitted!</p>
{{/if}}

<h2>Violations</h2>
{{#each violations}}
  <p>{{this.NOVDescription}} - {{this.ViolationStatus}}</p>
{{/each}}

<h2>Comments</h2>
{{#each comments}}
  <p>{{this.commentText}}</p>
{{/each}}


<h3>Add a comment</h3>
<form method='POST' action='/building/{{building.BIN}}/comment'>
  <label for="commentText">Comment:</label>
<input
  type='text'
  id='commentText'
  name='commentText'
  placeholder='Please write a comment'
  required
/>
  <button type='submit'>Submit</button>
</form>
{{#if comment_confirm_submit}}
  <p>Comment submitted!</p>
{{/if}}