{{#if review_confirm_submit}}
<p class="success">Review submitted!</p>
{{/if}}

{{#if comment_confirm_submit}}
<p class="success">Topic submitted!</p>
{{/if}}

<div class="building-tabs">
  <button id="overview-tab">Overview</button>
  <button id="reviews-tab">Reviews</button>
  <button id="violations-tab">Violations</button>
  <button id="comments-tab">Forum</button>
  <button id="associated-tab">Associated Buildings</button>
</div>



<div id="building-header" class="building-subheader">
  <span>{{building.address}}</span>
  <span>BIN: {{building.BIN}}</span>
</div>


<section id="overview" class="building-section">
  <div class="overview-card">
    <h1>{{building.address}}</h1>
    <p>BIN: {{building.BIN}}</p>
    <p>Avg Rating: {{round building.avgRating}} ({{building.reviewsCount}} review/s)</p>
    <p>Violations Count: {{violations_count}}</p>
    <p>Building Safety Score: {{violationSummary.rating}} / 5</p>
    <p>Total Violations: {{violationSummary.totalViolations}}</p>

    <p class="small-text">
      *Score weighs how many violations the building has and how serious they are. 5 is best.
    </p>

    {{#if favorite_exists}}
      <p class="error">This building has already been favorited by you.</p>
    {{/if}}

    {{#if isFavorite}}
      <form action="/favorites/{{building.BIN}}/remove" method="POST">
        <input type="hidden" name="redirectTo" value="/building/{{building.BIN}}" />
        <button type="submit">Unfavorite</button>
      </form>
    {{else}}
      <form action="/favorites/{{building.BIN}}" method="POST">
        <input type="hidden" name="redirectTo" value="/building/{{building.BIN}}" />
        <button type="submit">Save to Favorites</button>
      </form>
    {{/if}}
  </div>
</section>

<section id="reviews" class="building-section">
  <h2>Reviews</h2>
    <h3>Average Rating: {{round building.avgRating}} ({{building.reviewsCount}} review/s)</h3>

  {{#each reviews}}
    {{> reviewscard}}
  {{/each}}

  <h3>Add a review</h3>

  <form method="POST" action="/building/{{building.BIN}}/review">
    <label for="reviewText">Review:</label>
    <input type="text" id="reviewText" name="reviewText" placeholder="Please write a review" required />

    <label for="rating">Rating (1-5):</label>
    <input type="number" id="rating" name="rating" min="1" max="5" required />

    <button type="submit">Submit</button>
  </form>
</section>

<section id="violations" class="building-section">
  <h2>Violations Summary</h2>

  <div class="violation-stats">
    <div class="vio-card">
      <h3>Class C</h3>
      <span>Most Severe</span>
      <p class="vio-count">{{vioClassCounts.C}}</p>
    </div>

    <div class="vio-card">
      <h3>Class B</h3>
      <span>Hazardous</span>
      <p class="vio-count">{{vioClassCounts.B}}</p>
    </div>

    <div class="vio-card">
      <h3>Class A</h3>
      <span>Non-Hazardous</span>
      <p class="vio-count">{{vioClassCounts.A}}</p>
    </div>

    <div class="vio-card">
      <h3>Class I</h3>
      <span>Information</span>
      <p class="vio-count">{{vioClassCounts.I}}</p>
    </div>
  </div>

  {{#if vioSorted.length}}
    <table>
      <tr>
        <th><a href="/building/{{building.BIN}}?sortBy=class">Class</a></th>
        <th><a href="/building/{{building.BIN}}?sortBy=status">Status</a></th>
        <th><a href="/building/{{building.BIN}}?sortBy=inspectionDate">Inspection Date</a></th>
        <th><a href="/building/{{building.BIN}}?sortBy=statusDate">Status Updated</a></th>
        <th>Description</th>
      </tr>

      {{#each vioSorted}}
        <tr>
          <td>{{this.class}}</td>
          <td>{{this.violationStatus}}</td>
          <td>{{this.inspectionDate}}</td>
          <td>{{this.currentStatusDate}}</td>
          <td>{{this.description}}</td>
        </tr>
      {{/each}}
    </table>
  {{else}}
    <p>No violations found for this building.</p>
  {{/if}}
</section>

<section id="comments" class="building-section">
  <h2>Forum</h2>

  {{#each comments}}
    <div class="forum-topic">
      <button class="topic-toggle">
        {{this.comment.topicTitle}} — {{this.comment.userId.firstName}}
      </button>

      <div class="topic-content">
        <h4>Replies</h4>

        {{#if this.replies.length}}
          {{#each this.replies}}
            <p>{{this.replyText}} — <span class="username">{{this.userId.firstName}}</span> ({{this.userId.activityScore}} karma)</p>
          {{/each}}
        {{else}}
          <p>No replies yet.</p>
        {{/if}}

        <form method="POST" action="/topic/{{this.comment._id}}/reply">
          <input type="hidden" name="buildingBIN" value="{{@root.building.BIN}}" />
          <textarea name="replyText" placeholder="Write a reply" required></textarea>
          <button type="submit">Reply</button>
        </form>
      </div>
    </div>
  {{/each}}

  <h3>Create A Topic</h3>

  <form method="POST" action="/building/{{building.BIN}}/comment">
    <label for="topicTitle">Topic Title:</label>
    <input type="text" id="topicTitle" name="topicTitle" placeholder="Please enter a topic title" required />
    <button type="submit">Create Topic</button>
  </form>
</section>

<section id="associated" class="building-section">
  <h2>Associated Buildings</h2>

  <p><span class="label">Registration ID:</span> {{regID}}</p>
  <p><span class="label">Buildings Found:</span> {{assoc_bldgs.length}}</p>

  <table>
    <tr>
      <th>Address</th>
      <th>BIN</th>
      <th>Avg Rating</th>
      <th>Safety Score</th>
      <th>Violations</th>
    </tr>

    {{#if assoc_bldgs.length}}
      {{#each assoc_bldgs}}
        <tr>
          <td>
            <a href="/building/{{this.BIN}}">
              {{this.address}}
            </a>
          </td>

          <td>
            <a href="/building/{{this.BIN}}">
              {{this.BIN}}
            </a>
          </td>

          <td>{{this.avgRating}}</td>
          <td>{{this.safetyScore}}</td>
          <td>{{this.violationsCount}}</td>
        </tr>
      {{/each}}
    {{else}}
      <tr>
        <td colspan="5">Couldn't find any other buildings that have the same landlord</td>
      </tr>
    {{/if}}
  </table>
</section>

<script src="/public/js/building_page.js"></script>