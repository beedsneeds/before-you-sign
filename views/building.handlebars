  {{#if review_confirm_submit}}
    <p class ="success">Review submitted!</p>
  {{/if}}

  {{#if comment_confirm_submit}}
    <p class ="success">Comment submitted!</p>
  {{/if}}

<div class="building-tabs">
  <button id="overview-tab">Overview</button>
  <button id="reviews-tab">Reviews</button>
  <button id="violations-tab">Violations</button>
  <button id="comments-tab">Comments</button>
</div>



<section id="overview" class="building-section">
  <div class="overview-card">
  <h1>{{building.address}}</h1>
  <p>BIN: {{building.BIN}}</p>

  <p>Avg Rating: {{building.avgRating}}</p>
  <p>Reviews Count: {{building.reviewsCount}}</p>
  <p>Violations Count: {{violations_count}}</p>
      {{#if favorite_exists}}
  <p class="error">This building has already been favorited by you.</p>
{{/if}}
      <form action="/favorites/{{building._id}}" method="POST">
      <button type="submit">
        Save to Favorites
      </button>
      </form>
</div>
</section>

<section id="reviews" class="building-section">
  <h2>Reviews</h2>

  {{#each reviews}}
    {{> reviewscard}}
  {{/each}}

  <h3>Add a review</h3>

  <form method='POST' action='/building/{{building.BIN}}/review'>
    <label for='reviewText'>Review:</label>

    <input
      type='text'
      id='reviewText'
      name='reviewText'
      placeholder='Please write a review'
      required
    />

    <label for='rating'>Rating (1-5):</label>

    <input
      type='number'
      id='rating'
      name='rating'
      min='1'
      max='5'
      required
    />

    <button type='submit'>Submit</button>
  </form>

</section>

<section id="violations" class="building-section">
  <h2>Violations Summary</h2>
<div class="violation-stats">

<div class="vio-card">
  <h3>Class C</h3>
  <span>Most Severe</span>
  <p class="vio-count">{{vioClassCounts.C}}</p>
</div>

<div class="vio-card">
  <h3>Class B</h3>
  <span>Hazardous</span>
  <p class="vio-count">{{vioClassCounts.B}}</p>
</div>

<div class="vio-card">
  <h3>Class A</h3>
  <span>Non-Hazardous</span>
  <p class="vio-count">{{vioClassCounts.A}}</p>
</div>

<div class="vio-card">
  <h3>Class I</h3>
  <span>Information</span>
  <p class="vio-count">{{vioClassCounts.I}}</p>
</div>


</div>
  {{#if vioSorted.length}}
<table>
  <tr>
    <th>
      <a href="/building/{{building.BIN}}?sortBy=class">
        Class
      </a>
    </th>

    <th>
      <a href="/building/{{building.BIN}}?sortBy=status">
        Status
      </a>
    </th>

    <th>
      <a href="/building/{{building.BIN}}?sortBy=inspectionDate">
        Inspection Date
      </a>
    </th>

    <th>
      <a href="/building/{{building.BIN}}?sortBy=statusDate">
        Status Updated
      </a>
    </th>

   <th>Description</th>
  </tr>

  {{#each vioSorted}}
    <tr>
      <td>{{this.class}}</td>
      <td>{{this.violationStatus}}</td>
      <td>{{this.inspectionDate}}</td>
      <td>{{this.currentStatusDate}}</td>
      <td>{{this.description}}</td>
    </tr>
  {{/each}}

</table>

{{else}}

<p>No violations found for this building.</p>

{{/if}}

</section>

<section id="comments" class="building-section">
  <h2>Comments</h2>

  {{#each comments}}
    <p>{{this.commentText}}</p>
  {{/each}}

  <h3>Add a comment</h3>

  <form method='POST' action='/building/{{building.BIN}}/comment'>
    <label for="commentText">Comment:</label>

    <input
      type='text'
      id='commentText'
      name='commentText'
      placeholder='Please write a comment'
      required
    />

    <button type='submit'>Submit</button>
  </form>


</section>