<section class="home-page">
  <img src="/public/images/logo.png" alt="Before You Sign logo" class="home-logo" >

  <h1 id="appTitle">Before You Sign</h1>

  <p id="siteDescription">
    Welcome to Before You Sign, your one-stop shop for renting questions before you sign a lease.
  </p>

  <form action="/search" method="GET" class="home-search-form">
    <label for="searchQuery" class="visually-hidden">Search for a building</label>
    <input
      type="text"
      name="search"
      id="searchQuery"
      placeholder="Search by address, building name, or BIN"
    >
    <input type="submit" value="Search" class="search-button" >
  </form>

  {{#unless loggedIn}}
    <p>
      <a id="registerlink" href="/register">Register Here</a>
    </p>
    <p>
      <a id="signinlink" href="/signin">Sign In Here</a>
    </p>
  {{/unless}}

  {{#if loggedIn}}
    {{#if isAdmin}}
      <p>
        <a id="managerlink" href="/admin">Admin Dashboard</a>
      </p>
    {{/if}}

    <p>
      <a id="signoutlink" href="/signout">Sign Out</a>
    </p>
  {{/if}}

  <footer id="siteFooter">
    Check the building before you sign the lease.
  </footer>
</section>