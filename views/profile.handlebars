<h1>Profile</h1>

<div class='profile-grid'>
  <section class='profile-card profile-main-card'>
    <h2>User Information</h2>
    <p><span class="label">Name:</span> {{user.firstName}} {{user.lastName}}</p>
    <p><span class="label">Email:</span> {{user.email}}</p>
    <p><span class="label">Admin status:</span> {{#if user.isAdmin}}Yes{{else}}No{{/if}}</p>
    <p><span class="label">Activity score:</span> {{user.activityScore}}</p>
    <p><span class="label">Saved buildings:</span> {{savedBuildings.length}}</p>
    <p><span class="label">Reviews:</span> {{reviews.length}}</p>
    <p><span class="label">Comments:</span> {{comments.length}}</p>
    <a class='button' href='/profile/edit'>Edit profile</a>
  </section>

  <section class='profile-card profile-half-card'>
    <h2>Saved Buildings</h2>
    {{#if savedBuildings.length}}
      <ul>
        {{#each savedBuildings}}
          <li>
            <a href='/building/{{BIN}}'>{{address}} (BIN: {{BIN}})</a>
          </li>
        {{/each}}
      </ul>
      <a href='/favorites'>Manage favorites</a>
    {{else}}
      <p>No saved buildings yet.</p>
      <a href='/favorites'>Go to favorites</a>
    {{/if}}
  </section>

  <section class='profile-card profile-half-card'>
    <h2>Reviews & Topics</h2>

    {{#if reviews.length}}
      <h3>Reviews</h3>
      <ul>
        {{#each reviews}}
          <li>
            <span class="label">{{#if buildingId}}{{buildingId.address}}{{else}}Building{{/if}}</span>
            {{#if buildingId}}(BIN: {{buildingId.BIN}}){{/if}}<br >
            Rating:
            {{rating}}<br >
            {{reviewText}}
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p>No reviews yet.</p>
    {{/if}}

    {{#if comments.length}}
      <h3>Topics Shared</h3>
      <ul>
        {{#each comments}}
          <li>
            <span class="label">{{#if buildingId}}{{buildingId.address}}{{else}}Building{{/if}}</span>
            {{#if buildingId}}(BIN: {{buildingId.BIN}}){{/if}}<br >
            {{topicTitle}}
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p>No comments yet.</p>
    {{/if}}
  </section>
</div>